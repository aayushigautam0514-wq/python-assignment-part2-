        "##1. deepcopy\n",
        "\n",
        "inventory_backup = copy.deepcopy(inventory)\n",
        "\n",
        "##Manually changing a value to prove deep copy works\n",
        "\n",
        "inventory[\"Garlic Naan\"][\"stock\"] = 999\n",
        "\n",
        "print(\"After manual change:\")\n",
        "print(\"inventory Garlic Naan stock        :\", inventory[\"Garlic Naan\"][\"stock\"])\n",
        "print(\"inventory_backup Garlic Naan stock :\", inventory_backup[\"Garlic Naan\"][\"stock\"])\n",
        "print(\"Backup is unaffected — deep copy confirmed.\")\n",
        "print()\n",
        "\n",
        "##Restore inventory to original\n",
        "\n",
        "inventory[\"Garlic Naan\"][\"stock\"] = 30\n",
