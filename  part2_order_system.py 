        "    reorder = inventory[item][\"reorder_level\"]\n",
        "\n",
        "    if stock <= reorder:\n",
        "        print(\"⚠ Reorder Alert:\", item, \"— Only\", stock,\n",
        "              \"unit(s) left (reorder level:\", str(reorder) + \")\")\n",
        "        alert_found = True\n",
        "\n",
        "if alert_found == False:\n",
        "    print(\"All items are sufficiently stocked.\")\n",
        "\n",
        "print()\n",
        "\n",
        "##4. inventory and inventory_backup\n",
        "\n",
        "print(\"-- Final Comparison --\")\n",
        "print()\n",
        "print(\"Current inventory (after deductions):\")\n",
        "for item in inventory:\n",
        "    print(\" \", item, \":\", inventory[item][\"stock\"], \"units\")\n",
        "\n",
        "print()\n",
        "print(\"Backup inventory (unchanged original):\")\n",
        "for item in inventory_backup:\n",
        "    print(\" \", item, \":\", inventory_backup[item][\"stock\"], \"units\")\n",
        "\n",
        "print()\n",
        "print(\"-- Items that differ --\")\n",
