        "print()\n",
        "\n",
        "##2.  deduct the quantities from the final cart in Task 2\n",
        "\n",
        "print(\"-- Fulfilling Order --\")\n",
        "\n",
        "for entry in cart:\n",
        "    item_name = entry[\"item\"]\n",
        "    qty_needed = entry[\"quantity\"]\n",
        "\n",
        "    if item_name in inventory:\n",
        "        current_stock = inventory[item_name][\"stock\"]\n",
        "\n",
        "        if current_stock < qty_needed:\n",
        "            print(\"Warning: Not enough stock for\", item_name + \".\",\n",
        "                  \"Requested:\", qty_needed, \"| Available:\", current_stock,\n",
        "                  \"| Deducting only\", current_stock)\n",
        "            inventory[item_name][\"stock\"] = 0\n",
        "        else:\n",
        "            inventory[item_name][\"stock\"] = current_stock - qty_needed\n",
        "            print(\"Deducted\", qty_needed, \"unit(s) of\", item_name + \".\",\n",
        "                  \"Remaining stock:\", inventory[item_name][\"stock\"])\n",
        "    else:\n",
        "        print(item_name, \"not found in inventory.\")\n",
        "\n",
        "print()\n",
        "\n",
        "##3. Reorder Alert\n",
        "\n",
        "print(\"-- Reorder Alerts --\")\n",
        "\n",
        "alert_found = False\n",
        "\n",
        "for item in inventory:\n",
